---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon/components";

const highlights = [
  {
    title: "Team workspaces",
    description:
      "Bring your organization's clusters, teams, and ownership into one shared, governed surface.",
    icon: "bx:bxs-group",
  },
  {
    title: "Scorecards & standards",
    description:
      "Reliability, security, and cost hygiene scorecards so every team knows what 'production-ready' means.",
    icon: "bx:bxs-badge-check",
  },
  {
    title: "Governance & audit",
    description:
      "RBAC, audit logs, and policy-as-code to keep platform operations safe and accountable at scale.",
    icon: "bx:bxs-shield-alt-2",
  },
];
---

<Layout title="TiderOps Platform">
  <Container>
    <Sectionhead>
      <Fragment slot="title">TiderOps Platform</Fragment>
      <Fragment slot="desc">
        The internal developer platform (IDP) for organizations running
        Kubernetes — coming soon.
      </Fragment>
    </Sectionhead>

    <div class="flex flex-col items-center text-center mx-auto max-w-2xl mt-12">
      <span
        class="inline-flex items-center gap-1.5 rounded-full bg-slate-100 text-muted text-sm font-medium px-3 py-1">
        <Icon class="w-4 h-4" name="bx:bxs-time" /> Coming soon
      </span>
      <p class="text-lg mt-6 text-muted">
        TiderOps Platform extends Tider from a single-engineer desktop tool into
        a team platform: shared workspaces, scorecards, governance, and
        operational standards across every cluster in your organization.
      </p>
      <div class="mt-8">
        <Link
          href="mailto:hello@tiderops.io?subject=Notify%20me%20about%20TiderOps%20Platform"
          class="bg-primary hover:bg-primary-600 text-white border-transparent inline-flex gap-2 items-center justify-center">
          <Icon class="w-5 h-5" name="bx:bxs-bell" />
          Notify me
        </Link>
      </div>
    </div>

    <div class="grid sm:grid-cols-3 gap-8 mx-auto max-w-5xl mt-20 mb-8">
      {
        highlights.map((item) => (
          <div class="rounded-lg border border-slate-200 p-6">
            <div class="bg-primary rounded-full p-2 w-10 h-10 flex items-center justify-center">
              <Icon class="text-white w-5 h-5" name={item.icon} />
            </div>
            <h3 class="font-semibold text-lg mt-4 text-ink">{item.title}</h3>
            <p class="text-muted mt-2 leading-relaxed">{item.description}</p>
          </div>
        ))
      }
    </div>
  </Container>
</Layout>
