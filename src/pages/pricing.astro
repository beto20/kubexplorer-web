---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import PricingCard from "@components/pricing.astro";

const pricing = [
  {
    name: "Community",
    price: "Free",
    tagline: "Open source, forever.",
    popular: false,
    features: [
      "Multi-cluster management",
      "Cluster monitoring & dashboards",
      "Resource backup & restore",
      "Unlimited clusters",
      "All core features",
      "Community support",
    ],
    button: {
      text: "Download for Free",
      link: "https://github.com/beto20/kubexplorer/releases",
      external: true,
    },
  },
  {
    name: "Professional",
    price: "$12",
    period: "/ user / mo",
    tagline: "For teams that want more power.",
    popular: true,
    features: [
      "Everything in Community",
      "Resource optimization (heuristic)",
      "Troubleshooting assistant",
      "Advanced monitoring & alerts",
      "Scheduled & remote backups",
      "Priority email support",
    ],
    button: {
      text: "Coming soon",
      disabled: true,
    },
  },
  {
    name: "Enterprise",
    price: "Custom",
    tagline: "For organizations at scale.",
    popular: false,
    features: [
      "Everything in Professional",
      "SSO & SAML integration",
      "RBAC & audit logs",
      "Dedicated onboarding",
      "99.9% uptime SLA",
      "24/7 priority support",
    ],
    button: {
      text: "Contact Sales",
      link: "mailto:hello@kubexplorer.io",
      external: true,
    },
  },
];
---

<Layout title="Pricing">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Pricing</Fragment>
      <Fragment slot="desc">
        Start free and open source. Upgrade when your team needs more.
      </Fragment>
    </Sectionhead>

    <div
      class="grid md:grid-cols-3 gap-8 items-stretch mx-auto max-w-screen-lg mt-16">
      {pricing.map((item) => <PricingCard plan={item} />)}
    </div>

    <p class="text-center text-muted mt-10">
      All plans are built on the open-source Kubexplorer core. Questions about
      pricing?{" "}
      <a
        href="mailto:hello@kubexplorer.io"
        class="text-primary font-medium hover:underline">Get in touch</a
      >.
    </p>
  </Container>
</Layout>
