---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon/components";

const highlights = [
  {
    title: "Diagnose",
    description:
      "Correlate events, logs, metrics, and state into one diagnostic timeline so you see what actually broke.",
    icon: "bx:bxs-file-find",
  },
  {
    title: "Attribute",
    description:
      "Tie failures to the deploy or GitOps change that caused them, with blast radius and ownership.",
    icon: "bx:bx-git-branch",
  },
  {
    title: "Fix safely",
    description:
      "Dry-run, policy checks, and rollback before any action — so you know whether the fix is safe.",
    icon: "bx:bxs-shield-alt-2",
  },
];
---

<Layout title="Tider Pilot">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Tider Pilot</Fragment>
      <Fragment slot="desc">
        The AI assistant for Kubernetes operations — coming soon.
      </Fragment>
    </Sectionhead>

    <div class="flex flex-col items-center text-center mx-auto max-w-2xl mt-12">
      <span
        class="inline-flex items-center gap-1.5 rounded-full bg-slate-100 text-muted text-sm font-medium px-3 py-1">
        <Icon class="w-4 h-4" name="bx:bxs-time" /> Coming soon
      </span>
      <p class="text-lg mt-6 text-muted">
        Tider Pilot is AI-assisted root cause and safe remediation built into
        TiderOps. It tells you what broke, what changed to cause it, and whether
        the fix is safe — and gets smarter from every cluster it sees.
      </p>
      <div class="mt-8">
        <Link
          href="mailto:hello@tiderops.io?subject=Notify%20me%20about%20Tider%20Pilot"
          class="bg-primary hover:bg-primary-600 text-white border-transparent inline-flex gap-2 items-center justify-center">
          <Icon class="w-5 h-5" name="bx:bxs-bell" />
          Notify me
        </Link>
      </div>
    </div>

    <div class="grid sm:grid-cols-3 gap-8 mx-auto max-w-5xl mt-20 mb-8">
      {
        highlights.map((item) => (
          <div class="rounded-lg border border-slate-200 p-6">
            <div class="bg-primary rounded-full p-2 w-10 h-10 flex items-center justify-center">
              <Icon class="text-white w-5 h-5" name={item.icon} />
            </div>
            <h3 class="font-semibold text-lg mt-4 text-ink">{item.title}</h3>
            <p class="text-muted mt-2 leading-relaxed">{item.description}</p>
          </div>
        ))
      }
    </div>
  </Container>
</Layout>
