---
import Container from "@components/container.astro";
import Link from "@components/ui/link.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";
import { Icon } from "astro-icon/components";

const menuitems = [
  { title: "Features", path: "/#features" },
  { title: "Pricing", path: "/pricing" },
  { title: "Docs", path: "/docs" },
  { title: "Community", path: "/community" },
  { title: "About", path: "/about" },
];
---

<Container>
  <header class="flex flex-col lg:flex-row justify-between items-center my-5">
    <Astronav>
      <div class="flex w-full lg:w-auto items-center justify-between">
        <a href="/" class="text-lg">
          <span class="font-bold text-ink">Kubexplorer</span>
        </a>
        <div class="block lg:hidden">
          <MenuIcon class="w-4 h-4 text-ink" />
        </div>
      </div>
      <MenuItems class="hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0 lg:items-center">
        <ul class="flex flex-col lg:flex-row lg:gap-3">
          {
            menuitems.map((item) => (
              <li>
                <a
                  href={item.path}
                  class="flex lg:px-3 py-2 items-center text-muted hover:text-primary transition">
                  <span>{item.title}</span>
                </a>
              </li>
            ))
          }
        </ul>
        <div class="lg:hidden flex items-center mt-3 gap-4">
          <a
            href="https://github.com/beto20/kubexplorer"
            target="_blank"
            rel="noopener"
            class="text-muted hover:text-primary transition">
            <Icon class="w-6 h-6" name="bx:bxl-github" />
          </a>
          <Link
            href="https://github.com/beto20/kubexplorer/releases"
            target="_blank"
            rel="noopener"
            size="md"
            class="bg-primary hover:bg-primary-600 text-white border-transparent">
            Download
          </Link>
        </div>
      </MenuItems>
    </Astronav>
    <div class="hidden lg:flex items-center gap-4">
      <a
        href="https://github.com/beto20/kubexplorer"
        target="_blank"
        rel="noopener"
        aria-label="Kubexplorer on GitHub"
        class="text-muted hover:text-primary transition">
        <Icon class="w-6 h-6" name="bx:bxl-github" />
      </a>
      <Link
        href="https://github.com/beto20/kubexplorer/releases"
        target="_blank"
        rel="noopener"
        size="md"
        class="bg-primary hover:bg-primary-600 text-white border-transparent">
        Download
      </Link>
    </div>
  </header>
</Container>
