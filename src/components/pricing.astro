---
import { Tick } from "@components/ui/icons";
import Link from "@components/ui/link.astro";

const { plan } = Astro.props;
---

<div
  class:list={[
    "relative flex flex-col w-full rounded-xl py-6 px-6 border-2",
    plan.popular
      ? "border-primary shadow-xl shadow-primary/10"
      : "border-slate-200",
  ]}>
  {
    plan.popular && (
      <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-primary text-white text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full">
        Most popular
      </span>
    )
  }
  <div class="text-center">
    <h4 class="text-lg font-medium text-muted">{plan.name}</h4>
    <p class="mt-3 text-4xl font-bold text-ink">
      {plan.price}
      {
        plan.period && (
          <span class="text-base font-medium text-muted">{plan.period}</span>
        )
      }
    </p>
    {
      plan.tagline && (
        <p class="mt-2 text-sm text-muted">{plan.tagline}</p>
      )
    }
  </div>

  <ul class="grid mt-8 text-left gap-y-4">
    {
      plan.features.map((item) => (
        <li class="flex items-start gap-3 text-ink">
          <Tick class="w-5 h-5 text-primary shrink-0 mt-0.5" />
          <span>{item}</span>
        </li>
      ))
    }
  </ul>

  <div class="flex mt-auto pt-8">
    <Link
      href={plan.button.link || "#"}
      block
      target={plan.button.external ? "_blank" : undefined}
      rel={plan.button.external ? "noopener" : undefined}
      style={plan.popular ? "primary" : "outline"}
      class={plan.popular
        ? "bg-primary hover:bg-primary-600 text-white border-transparent"
        : ""}>
      {plan.button.text || "Get Started"}
    </Link>
  </div>
</div>
