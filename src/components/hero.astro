---
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon/components";

const clusters = [
  { name: "production", status: "bg-green-500" },
  { name: "staging", status: "bg-primary" },
  { name: "dev-eu", status: "bg-amber-400" },
];

const stats = [
  { label: "Nodes", value: "24" },
  { label: "Pods", value: "318" },
  { label: "CPU", value: "62%" },
];

const bars = [55, 70, 40, 85, 60, 75, 50];
---

<main
  class="grid lg:grid-cols-2 gap-10 place-items-center pt-12 pb-8 md:pt-12 md:pb-24">
  <!-- Product mockup -->
  <div class="w-full py-6 md:order-1 hidden md:block">
    <div class="relative">
      <div
        class="absolute -inset-4 bg-primary/10 blur-2xl rounded-full"
        aria-hidden="true">
      </div>
      <div
        class="relative rounded-xl border border-slate-200 shadow-2xl bg-white overflow-hidden"
        role="img"
        aria-label="Tider dashboard preview">
        <!-- Window chrome -->
        <div
          class="flex items-center gap-2 px-4 py-3 bg-surface border-b border-slate-200">
          <span class="w-3 h-3 rounded-full bg-red-400"></span>
          <span class="w-3 h-3 rounded-full bg-amber-400"></span>
          <span class="w-3 h-3 rounded-full bg-green-400"></span>
          <span class="ml-3 text-xs text-muted truncate"
            >Tider — production</span
          >
        </div>
        <div class="flex">
          <!-- Sidebar -->
          <aside
            class="w-2/5 sm:w-1/3 bg-surface/60 border-r border-slate-200 p-3 space-y-2">
            <p class="text-[10px] uppercase tracking-wider text-muted px-1">
              Clusters
            </p>
            {
              clusters.map((c, i) => (
                <div
                  class:list={[
                    "flex items-center gap-2 rounded-md px-2 py-1.5 text-xs",
                    i === 0 ? "bg-primary/10 text-ink font-medium" : "text-muted",
                  ]}>
                  <span class:list={["w-2 h-2 rounded-full", c.status]} />
                  {c.name}
                </div>
              ))
            }
          </aside>
          <!-- Main panel -->
          <div class="flex-1 p-4 space-y-4">
            <div class="grid grid-cols-3 gap-3">
              {
                stats.map((s) => (
                  <div class="rounded-lg border border-slate-200 p-3">
                    <p class="text-[10px] uppercase tracking-wider text-muted">
                      {s.label}
                    </p>
                    <p class="text-lg font-bold text-ink mt-1">{s.value}</p>
                  </div>
                ))
              }
            </div>
            <div class="rounded-lg border border-slate-200 p-3">
              <p class="text-[10px] uppercase tracking-wider text-muted mb-2">
                Resource usage
              </p>
              <div class="flex items-end gap-2 h-20">
                {
                  bars.map((h) => (
                    <div
                      class="flex-1 bg-primary/80 rounded-t"
                      style={`height:${h}%`}
                    />
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Copy -->
  <div>

    <h1
      class="text-5xl lg:text-6xl xl:text-7xl font-bold lg:tracking-tight xl:tracking-tighter text-ink mt-4">
      Navigating Kubernetes has never been easier with <span class="text-primary"
        >Tider</span
      >
    </h1>
    <p class="text-lg mt-4 text-muted max-w-xl">
      Tider is a powerful open-source desktop application that transforms
      Kubernetes management. With a sleek, intuitive interface and support for
      multiple clusters, it helps teams move faster, automate smarter, and stay
      in control—without the complexity. It's the desktop app at the heart of
      the TiderOps suite.
    </p>
    <div class="mt-6 flex flex-col sm:flex-row gap-3">
      <Link
        href="https://github.com/tiderops/tider/releases"
        target="_blank"
        rel="noopener"
        class="bg-primary hover:bg-primary-600 text-white border-transparent flex gap-1 items-center justify-center">
        <Icon class="text-white w-5 h-5" name="bx:bxs-cloud-download" />
        Download for Free
      </Link>
      <Link
        size="lg"
        style="outline"
        rel="noopener"
        href="https://github.com/tiderops/tider"
        class="flex gap-1 items-center justify-center"
        target="_blank">
        <Icon class="text-black w-4 h-4" name="bx:bxl-github" />
        GitHub Repo
      </Link>
    </div>
  </div>
</main>
